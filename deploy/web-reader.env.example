# Copy to /etc/web-reader/web-reader.env, restrict permissions, and replace values.
WEB_READER_ADDR=0.0.0.0:8848
WEB_READER_WORKSPACE=/srv/books
WEB_READER_ADMIN_USERNAME=admin
WEB_READER_ADMIN_PASSWORD_HASH=$2a$10$replace_with_hash_from_web_reader_hash_password
WEB_READER_SESSION_TTL=24h
WEB_READER_MAX_TEXT_SIZE=10MiB

# Set true only when the browser reaches Web Reader through HTTPS.
WEB_READER_SECURE_COOKIE=false
